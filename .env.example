# Environment Configuration for Texas Hold'em Poker
# Copy this file to .env and fill in your values.

# ─── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── AI Provider (OpenAI-compatible) ─────────────────────────────
# Examples: OpenAI, DeepSeek, Moonshot, Qwen, Groq, Anyscale, etc.
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o-mini

# AI behavior tuning
AI_TIMEOUT_MS=15000
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=256
AI_FALLBACK_ENABLED=true

# ─── Security ────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins; leave empty to allow all (dev only)
CORS_ORIGINS=

# ─── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
