{
  "name": "texas-poker",
  "version": "1.0.0",
  "description": "Multiplayer Texas Hold'em Poker with real-time WebSocket play and LLM-powered AI opponents",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node --test backend/**/*.test.js frontend/js/**/*.test.js",
